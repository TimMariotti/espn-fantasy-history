---
import "../styles/global.css";
import { meta } from "../lib/data";

interface Props {
  title?: string;
  active?: string;
}

const { title = "League History", active = "home" } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const links = [
  { href: "/", key: "home", label: "Overview" },
  { href: "/seasons", key: "seasons", label: "Seasons" },
  { href: "/records", key: "records", label: "Records" },
  { href: "/drafts", key: "drafts", label: "Drafts" },
  { href: "/managers", key: "managers", label: "Managers" },
  { href: "/h2h", key: "h2h", label: "Head-to-Head" },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
  </head>
  <body>
    <nav class="nav">
      <div class="nav-inner">
        <a href={`${base}/`} class="nav-brand">League History</a>
        <input type="checkbox" id="nav-toggle" class="nav-toggle" aria-label="Toggle navigation" />
        <label for="nav-toggle" class="nav-burger" aria-hidden="true">
          <span></span><span></span><span></span>
        </label>
        <div class="nav-links">
          {
            links.map((l) => (
              <a href={`${base}${l.href}`} class={active === l.key ? "active" : ""}>
                {l.label}
              </a>
            ))
          }
        </div>
      </div>
    </nav>
    <main class="container">
      <slot />
      <footer>
        Data refreshed {new Date(meta.generated_at).toLocaleDateString()}
        · {meta.years.length} season(s) · League {meta.league_id}
      </footer>
    </main>
  </body>
</html>
