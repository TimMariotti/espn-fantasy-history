---
import Layout from "../../layouts/Layout.astro";
import {
  buildOwnerLeaderboard,
  buildAllPlay,
  buildScoreDistributions,
  ownerKey,
  ownerLabel,
  fmtScore,
} from "../../lib/data";

const leaderboard = buildOwnerLeaderboard();
const allPlay = buildAllPlay();
const distributions = buildScoreDistributions();
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

// Boxplot geometry
const BP_ROW_H = 26;
const BP_PAD_T = 20;
const BP_PAD_B = 28;
const BP_PAD_L = 110;
const BP_PAD_R = 24;
const BP_W = 760;
const BP_PLOT_W = BP_W - BP_PAD_L - BP_PAD_R;
const BP_H = BP_PAD_T + BP_PAD_B + distributions.length * BP_ROW_H;

const allMin = Math.min(...distributions.map((d) => d.min), Infinity);
const allMax = Math.max(...distributions.map((d) => d.max), -Infinity);
const xMin = Number.isFinite(allMin) ? Math.floor(allMin / 10) * 10 : 0;
const xMax = Number.isFinite(allMax) ? Math.ceil(allMax / 10) * 10 : 300;
const xSpan = Math.max(1, xMax - xMin);
const xPos = (v: number) => BP_PAD_L + ((v - xMin) / xSpan) * BP_PLOT_W;

// Gridline ticks every 25 points
const tickStep = 25;
const ticks: number[] = [];
for (let v = Math.ceil(xMin / tickStep) * tickStep; v <= xMax; v += tickStep) ticks.push(v);
---

<Layout title="Managers · League History" active="managers">
  <h1>Managers</h1>
  <div class="card">
    <table>
      <thead>
        <tr>
          <th>Manager</th>
          <th class="num">Seasons</th>
          <th class="num">W-L</th>
          <th class="num">Win %</th>
          <th class="num">All-Play %</th>
          <th class="num">PF</th>
          <th class="num">Titles</th>
          <th class="num">Best</th>
        </tr>
      </thead>
      <tbody>
        {
          leaderboard.map((r) => {
            const games = r.wins + r.losses + r.ties;
            const pct = games > 0 ? ((r.wins + r.ties * 0.5) / games) : 0;
            const ap = allPlay.get(ownerKey(r.owner));
            const apGames = ap ? ap.wins + ap.losses + ap.ties : 0;
            const apPct = apGames > 0 ? ((ap!.wins + ap!.ties * 0.5) / apGames) : null;
            return (
              <tr>
                <td>
                  <a href={`${base}/managers/${ownerKey(r.owner)}`}>{ownerLabel(r.owner)}</a>
                </td>
                <td class="num">{r.seasons}</td>
                <td class="num">{r.wins}-{r.losses}{r.ties ? `-${r.ties}` : ""}</td>
                <td class="num">{(pct * 100).toFixed(1)}%</td>
                <td class="num">
                  {apPct === null ? "—" : `${(apPct * 100).toFixed(1)}%`}
                  {ap && (
                    <span class="muted" style="font-size:0.75rem;display:block">
                      {ap.wins}-{ap.losses}{ap.ties ? `-${ap.ties}` : ""}
                    </span>
                  )}
                </td>
                <td class="num">{fmtScore(r.points_for)}</td>
                <td class="num">{r.championships}</td>
                <td class="num">{r.best_finish ?? "—"}</td>
              </tr>
            );
          })
        }
      </tbody>
    </table>
    <p class="muted" style="font-size:0.8rem;margin:0.5rem 0 0">
      All-Play: record vs the entire field each regular-season week (every team plays every team).
    </p>
  </div>

  <h2 style="margin-top:2rem">Weekly Score Distributions</h2>
  <p class="muted" style="margin-top:-0.25rem">
    Each row is a boxplot of every regular-season weekly score. Whiskers = min/max,
    box = 25th–75th percentile, line = median, dot = mean. Sorted by median.
  </p>
  <div class="card">
    <svg viewBox={`0 0 ${BP_W} ${BP_H}`} role="img" aria-label="Weekly score distributions" class="boxplot">
      {ticks.map((t) => {
        const x = xPos(t);
        return (
          <g>
            <line
              x1={x} x2={x}
              y1={BP_PAD_T} y2={BP_H - BP_PAD_B}
              stroke="#30363d" stroke-dasharray="2 4" stroke-width="1"
            />
            <text x={x} y={BP_H - BP_PAD_B + 16} fill="#8b949e" font-size="10" text-anchor="middle">
              {t}
            </text>
          </g>
        );
      })}
      {distributions.map((d, i) => {
        const cy = BP_PAD_T + BP_ROW_H * i + BP_ROW_H / 2;
        const boxH = 14;
        const boxY = cy - boxH / 2;
        const x1 = xPos(d.min);
        const xq1 = xPos(d.q1);
        const xMed = xPos(d.median);
        const xq3 = xPos(d.q3);
        const x2 = xPos(d.max);
        const xMean = xPos(d.mean);
        return (
          <g>
            <text x={BP_PAD_L - 8} y={cy + 4} fill="#c9d1d9" font-size="11" text-anchor="end">
              {ownerLabel(d.owner)}
            </text>
            <line x1={x1} x2={x2} y1={cy} y2={cy} stroke="#8b949e" stroke-width="1" />
            <line x1={x1} x2={x1} y1={cy - 4} y2={cy + 4} stroke="#8b949e" stroke-width="1" />
            <line x1={x2} x2={x2} y1={cy - 4} y2={cy + 4} stroke="#8b949e" stroke-width="1" />
            <rect
              x={xq1} y={boxY} width={Math.max(1, xq3 - xq1)} height={boxH}
              fill="#1f6feb33" stroke="#58a6ff" stroke-width="1"
            />
            <line x1={xMed} x2={xMed} y1={boxY} y2={boxY + boxH} stroke="#58a6ff" stroke-width="2" />
            <circle cx={xMean} cy={cy} r="2.5" fill="#d29922" />
            <title>
              {`${ownerLabel(d.owner)} — n=${d.count}\nmin ${fmtScore(d.min)} · Q1 ${fmtScore(d.q1)} · med ${fmtScore(d.median)} · Q3 ${fmtScore(d.q3)} · max ${fmtScore(d.max)}\nmean ${fmtScore(d.mean)}`}
            </title>
          </g>
        );
      })}
    </svg>
  </div>
</Layout>

<style>
  .boxplot { width: 100%; height: auto; display: block; }
</style>
