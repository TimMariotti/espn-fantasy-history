---
import Layout from "../layouts/Layout.astro";
import {
  buildDraftStats,
  ownerKey,
  ownerLabel,
  seasons,
  TRACKED_POSITIONS,
} from "../lib/data";

const stats = buildDraftStats();
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

// Aggregate first-round position pie across all drafts
const firstRoundAllTime: Record<string, number> = {};
for (const s of seasons) {
  for (const p of s.draft) {
    if (p.round === 1) {
      const pos = p.position || "?";
      firstRoundAllTime[pos] = (firstRoundAllTime[pos] || 0) + 1;
    }
  }
}
const firstRoundOrdered = Object.entries(firstRoundAllTime).sort((a, b) => b[1] - a[1]);
const firstRoundTotal = firstRoundOrdered.reduce((s, [, n]) => s + n, 0);

---

<Layout title="Drafts · League History" active="drafts">
  <h1>Draft Stats</h1>

  <h2>By Manager</h2>
  <div class="card" style="overflow-x:auto">
    <table>
      <thead>
        <tr>
          <th>Manager</th>
          {TRACKED_POSITIONS.map((p) => <th class="num">{p}</th>)}
        </tr>
      </thead>
      <tbody>
        {
          stats.map((s) => (
            <tr>
              <td>
                <a href={`${base}/managers/${ownerKey(s.owner)}`}>
                  {ownerLabel(s.owner)}
                </a>
              </td>
              {TRACKED_POSITIONS.map((pos) => (
                <td class="num">{s.positionCounts[pos] || 0}</td>
              ))}
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>

  <h2>Most-Drafted Players Per Manager</h2>
  <p class="muted">Players each manager has drafted in multiple years.</p>
  <div class="card">
    <table>
      <thead>
        <tr>
          <th>Manager</th>
          <th>Top Picks</th>
        </tr>
      </thead>
      <tbody>
        {
          stats.map((s) => {
            const repeated = s.topPlayers.filter((p) => p.count > 1);
            const display = repeated.length > 0 ? repeated : s.topPlayers.slice(0, 1);
            return (
              <tr>
                <td>
                  <a href={`${base}/managers/${ownerKey(s.owner)}`}>{ownerLabel(s.owner)}</a>
                </td>
                <td>
                  {display.map((p, i) => (
                    <span>
                      {i > 0 && <span class="muted">, </span>}
                      <strong>{p.name}</strong>
                      <span class="muted"> ({p.position ?? "—"}) × {p.count}</span>
                      <span class="muted" style="font-size:0.8em"> [{p.years.join(", ")}]</span>
                    </span>
                  ))}
                </td>
              </tr>
            );
          })
        }
      </tbody>
    </table>
  </div>

  <div class="card">
    <h2 style="margin-top:0">First-Round Positions (All Time)</h2>
    <table>
      <thead>
        <tr>
          <th>Position</th>
          <th class="num">Count</th>
          <th class="num">%</th>
        </tr>
      </thead>
      <tbody>
        {
          firstRoundOrdered.map(([pos, n]) => (
            <tr>
              <td>{pos}</td>
              <td class="num">{n}</td>
              <td class="num">{((n / firstRoundTotal) * 100).toFixed(1)}%</td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>
</Layout>
