---
import Layout from "../layouts/Layout.astro";
import {
  buildDraftStats,
  buildDraftValues,
  fmtScore,
  ownerKey,
  ownerLabel,
  seasons,
  teamOwnerLabel,
  TRACKED_POSITIONS,
} from "../lib/data";
import type { Owner } from "../lib/types";

const stats = buildDraftStats();
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const values = buildDraftValues();
// Steals/Busts cover real fantasy roster positions. K and D/ST are excluded —
// their week-to-week scoring is noise, not a draft skill signal.
const INCLUDED_POSITIONS = new Set(["QB", "RB", "WR", "TE"]);
const skillValues = values.filter((v) => v.pick.position !== null && INCLUDED_POSITIONS.has(v.pick.position));
const biggestSteals = [...skillValues].sort((a, b) => b.vodp - a.vodp).slice(0, 10);
const biggestBusts = [...skillValues]
  .filter((v) => v.overall <= 24) // top-2-rounds-ish, captures early-round flops
  .sort((a, b) => a.vodp - b.vodp)
  .slice(0, 10);
const bestLate = [...skillValues]
  .filter((v) => v.pick.round >= 8)
  .sort((a, b) => (b.pick.season_points ?? 0) - (a.pick.season_points ?? 0))
  .slice(0, 10);

// Per-season MVP + bust per year
type AwardRow = { year: number; steal?: typeof values[number]; bust?: typeof values[number] };
const byYear = new Map<number, typeof values>();
for (const v of skillValues) {
  const arr = byYear.get(v.season.year) ?? [];
  arr.push(v);
  byYear.set(v.season.year, arr);
}
const yearAwards: AwardRow[] = [];
for (const [year, vs] of Array.from(byYear.entries()).sort((a, b) => b[0] - a[0])) {
  const steal = [...vs].sort((a, b) => b.vodp - a.vodp)[0];
  const early = vs.filter((v) => v.overall <= 24);
  const bust = early.length ? [...early].sort((a, b) => a.vodp - b.vodp)[0] : undefined;
  yearAwards.push({ year, steal, bust });
}

// Aggregate first-round position pie across all drafts
const firstRoundAllTime: Record<string, number> = {};
for (const s of seasons) {
  for (const p of s.draft) {
    if (p.round === 1) {
      const pos = p.position || "?";
      firstRoundAllTime[pos] = (firstRoundAllTime[pos] || 0) + 1;
    }
  }
}
const firstRoundOrdered = Object.entries(firstRoundAllTime).sort((a, b) => b[1] - a[1]);
const firstRoundTotal = firstRoundOrdered.reduce((s, [, n]) => s + n, 0);

// Position tendency by round, per manager (counts across all years)
const POSITION_ORDER = ["QB", "RB", "WR", "TE", "K", "D/ST"] as const;
const POSITION_COLORS: Record<string, string> = {
  QB: "#58a6ff",
  RB: "#3fb950",
  WR: "#f0883e",
  TE: "#bc8cff",
  K: "#d29922",
  "D/ST": "#f85149",
  "?": "#8b949e",
};

type RoundCounts = Record<string, number>;
type OwnerRoundData = {
  ownerKey: string;
  ownerLabel: string;
  rounds: RoundCounts[]; // rounds[roundIndex] -> positionCounts; rounds[0] is round 1
  maxRoundTotal: number;
};

const ownerRoundMap = new Map<string, OwnerRoundData>();
let globalMaxRound = 0;
for (const s of seasons) {
  const teamOwners = new Map<number, Owner[]>(s.teams.map((t) => [t.id, t.owners]));
  for (const pick of s.draft) {
    if (pick.team_id === null) continue;
    const owners = teamOwners.get(pick.team_id) || [];
    if (pick.round > globalMaxRound) globalMaxRound = pick.round;
    const pos = pick.position || "?";
    for (const owner of owners) {
      const key = ownerKey(owner);
      let rec = ownerRoundMap.get(key);
      if (!rec) {
        rec = { ownerKey: key, ownerLabel: ownerLabel(owner), rounds: [], maxRoundTotal: 0 };
        ownerRoundMap.set(key, rec);
      }
      const idx = pick.round - 1;
      while (rec.rounds.length <= idx) rec.rounds.push({});
      rec.rounds[idx][pos] = (rec.rounds[idx][pos] || 0) + 1;
    }
  }
}
for (const rec of ownerRoundMap.values()) {
  while (rec.rounds.length < globalMaxRound) rec.rounds.push({});
  for (const r of rec.rounds) {
    const total = Object.values(r).reduce((a, b) => a + b, 0);
    if (total > rec.maxRoundTotal) rec.maxRoundTotal = total;
  }
}
const ownerCharts: OwnerRoundData[] = Array.from(ownerRoundMap.values()).sort((a, b) =>
  a.ownerLabel.localeCompare(b.ownerLabel),
);
const defaultOwnerKey = ownerCharts[0]?.ownerKey ?? "";

// SVG geometry for position bar chart
const PB_W = 800;
const PB_H = 340;
const PB_PAD_L = 40;
const PB_PAD_R = 16;
const PB_PAD_T = 16;
const PB_PAD_B = 32;
const PB_PLOT_W = PB_W - PB_PAD_L - PB_PAD_R;
const PB_PLOT_H = PB_H - PB_PAD_T - PB_PAD_B;

type BarSegment = { pos: string; y: number; h: number; count: number };
type BarChart = {
  ownerKey: string;
  ownerLabel: string;
  rounds: number;
  yMax: number;
  yTicks: number[];
  bars: { round: number; x: number; w: number; total: number; segments: BarSegment[] }[];
};

function tickValues(max: number): number[] {
  if (max <= 0) return [0];
  const target = 5;
  const raw = max / target;
  const mag = Math.pow(10, Math.floor(Math.log10(raw)));
  const norm = raw / mag;
  const step = (norm < 1.5 ? 1 : norm < 3 ? 2 : norm < 7 ? 5 : 10) * mag;
  const ticks: number[] = [];
  for (let v = 0; v <= max + step / 2; v += step) ticks.push(Math.round(v));
  return ticks;
}

const barCharts: BarChart[] = ownerCharts.map((rec) => {
  const yMax = Math.max(1, rec.maxRoundTotal);
  const ticks = tickValues(yMax);
  const top = ticks[ticks.length - 1];
  const rounds = rec.rounds.length;
  const slot = PB_PLOT_W / rounds;
  const barW = slot * 0.7;
  const bars = rec.rounds.map((counts, idx) => {
    const total = Object.values(counts).reduce((a, b) => a + b, 0);
    const x = PB_PAD_L + slot * idx + (slot - barW) / 2;
    let cursor = PB_PAD_T + PB_PLOT_H;
    const segments: BarSegment[] = [];
    for (const pos of POSITION_ORDER) {
      const n = counts[pos] || 0;
      if (!n) continue;
      const h = (n / top) * PB_PLOT_H;
      cursor -= h;
      segments.push({ pos, y: cursor, h, count: n });
    }
    const extras = Object.keys(counts).filter((p) => !POSITION_ORDER.includes(p as any));
    for (const pos of extras) {
      const n = counts[pos];
      const h = (n / top) * PB_PLOT_H;
      cursor -= h;
      segments.push({ pos, y: cursor, h, count: n });
    }
    return { round: idx + 1, x, w: barW, total, segments };
  });
  return { ownerKey: rec.ownerKey, ownerLabel: rec.ownerLabel, rounds, yMax: top, yTicks: ticks, bars };
});

const positionLegend = POSITION_ORDER.filter((p) =>
  ownerCharts.some((o) => o.rounds.some((r) => (r[p] || 0) > 0)),
);

---

<Layout title="Drafts · League History" active="drafts">
  <h1>Draft Stats</h1>

  {barCharts.length > 0 && (
    <div class="card position-chart-card">
      <div class="position-chart-header">
        <div>
          <h2 style="margin:0;border:0;padding:0">Position Tendency by Round</h2>
          <p class="muted" style="margin:0.25rem 0 0;font-size:0.85rem">
            Total picks by position in each round, across all drafted years.
          </p>
        </div>
        <label class="position-owner-picker">
          <span class="muted">Manager</span>
          <select id="position-owner">
            {barCharts.map((c) => (
              <option value={c.ownerKey} selected={c.ownerKey === defaultOwnerKey}>{c.ownerLabel}</option>
            ))}
          </select>
        </label>
      </div>

      {barCharts.map((c) => (
        <div
          class="position-chart"
          data-owner={c.ownerKey}
          style={c.ownerKey === defaultOwnerKey ? "" : "display:none"}
        >
          <svg viewBox={`0 0 ${PB_W} ${PB_H}`} role="img" aria-label={`${c.ownerLabel} position tendency by round`}>
            {c.yTicks.map((t) => {
              const y = PB_PAD_T + PB_PLOT_H - (t / c.yMax) * PB_PLOT_H;
              return (
                <g>
                  <line x1={PB_PAD_L} x2={PB_W - PB_PAD_R} y1={y} y2={y} stroke="#30363d" stroke-dasharray={t === 0 ? "" : "2 4"} stroke-width="1" />
                  <text x={PB_PAD_L - 6} y={y + 4} fill="#8b949e" font-size="10" text-anchor="end">{t}</text>
                </g>
              );
            })}
            {c.bars.map((b) => (
              <g>
                {b.segments.map((seg) => (
                  <rect x={b.x} y={seg.y} width={b.w} height={seg.h} fill={POSITION_COLORS[seg.pos] || "#8b949e"}>
                    <title>{`Round ${b.round} · ${seg.pos}: ${seg.count}`}</title>
                  </rect>
                ))}
                <text
                  x={b.x + b.w / 2}
                  y={PB_PAD_T + PB_PLOT_H + 14}
                  fill="#8b949e"
                  font-size="10"
                  text-anchor="middle"
                >
                  R{b.round}
                </text>
              </g>
            ))}
          </svg>
          <ul class="position-legend">
            {positionLegend.map((p) => (
              <li>
                <span class="swatch" style={`background:${POSITION_COLORS[p]}`}></span>
                {p}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  )}

  <h2>Biggest Steals & Busts</h2>
  <p class="muted">
    VODP (Value Over Draft Position) = positional draft order − positional finish rank.
    e.g. drafted 8th QB of the year, finished QB1 → +7. Positive = steal, negative = bust.
    Limited to QB/RB/WR/TE; keepers excluded.
  </p>

  <div class="grid" style="grid-template-columns:repeat(auto-fit,minmax(480px,1fr))">
    <div class="card" style="overflow-x:auto">
      <h3 style="margin-top:0">All-Time Biggest Steals</h3>
      <table>
        <thead>
          <tr>
            <th>#</th>
            <th>Player</th>
            <th>By</th>
            <th class="num">Pick</th>
            <th class="num">Pts</th>
            <th class="num">VODP</th>
          </tr>
        </thead>
        <tbody>
          {biggestSteals.map((v, i) => (
            <tr>
              <td>{i + 1}</td>
              <td>
                <strong>{v.pick.player_name}</strong>
                <span class="muted"> ({v.pick.position}{v.posDraftOrder} → {v.pick.position}{v.posFinishRank})</span>
              </td>
              <td class="muted">{v.team ? teamOwnerLabel(v.team) : "?"} · {v.season.year}</td>
              <td class="num">#{v.overall}</td>
              <td class="num">{v.pick.season_points !== null ? fmtScore(v.pick.season_points) : "—"}</td>
              <td class="num win">+{v.vodp}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <div class="card" style="overflow-x:auto">
      <h3 style="margin-top:0">All-Time Biggest Busts</h3>
      <p class="muted" style="margin-top:-0.5rem;font-size:0.85em">Top-2-rounds-ish picks who flopped.</p>
      <table>
        <thead>
          <tr>
            <th>#</th>
            <th>Player</th>
            <th>By</th>
            <th class="num">Pick</th>
            <th class="num">Pts</th>
            <th class="num">VODP</th>
          </tr>
        </thead>
        <tbody>
          {biggestBusts.map((v, i) => (
            <tr>
              <td>{i + 1}</td>
              <td>
                <strong>{v.pick.player_name}</strong>
                <span class="muted"> ({v.pick.position}{v.posDraftOrder} → {v.pick.position}{v.posFinishRank})</span>
              </td>
              <td class="muted">{v.team ? teamOwnerLabel(v.team) : "?"} · {v.season.year}</td>
              <td class="num">#{v.overall}</td>
              <td class="num">{v.pick.season_points !== null ? fmtScore(v.pick.season_points) : "—"}</td>
              <td class="num loss">{v.vodp}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <div class="card" style="overflow-x:auto">
      <h3 style="margin-top:0">Best Late-Round Picks (R8+)</h3>
      <table>
        <thead>
          <tr>
            <th>#</th>
            <th>Player</th>
            <th>By</th>
            <th class="num">Pick</th>
            <th class="num">Pts</th>
          </tr>
        </thead>
        <tbody>
          {bestLate.map((v, i) => (
            <tr>
              <td>{i + 1}</td>
              <td>
                <strong>{v.pick.player_name}</strong>
                <span class="muted"> ({v.pick.position ?? "—"})</span>
              </td>
              <td class="muted">{v.team ? teamOwnerLabel(v.team) : "?"} · {v.season.year}</td>
              <td class="num">R{v.pick.round}.{String(v.pick.pick).padStart(2, "0")}</td>
              <td class="num">{v.pick.season_points !== null ? fmtScore(v.pick.season_points) : "—"}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <div class="card" style="overflow-x:auto">
      <h3 style="margin-top:0">Steal & Bust of the Year</h3>
      <table>
        <thead>
          <tr>
            <th>Year</th>
            <th>Steal</th>
            <th>Bust</th>
          </tr>
        </thead>
        <tbody>
          {yearAwards.map((a) => (
            <tr>
              <td>{a.year}</td>
              <td>
                {a.steal ? (
                  <>
                    <strong>{a.steal.pick.player_name}</strong>
                    <span class="muted"> · {a.steal.pick.position}{a.steal.posDraftOrder}→{a.steal.pick.position}{a.steal.posFinishRank} · </span>
                    <span class="win">+{a.steal.vodp}</span>
                  </>
                ) : "—"}
              </td>
              <td>
                {a.bust ? (
                  <>
                    <strong>{a.bust.pick.player_name}</strong>
                    <span class="muted"> · {a.bust.pick.position}{a.bust.posDraftOrder}→{a.bust.pick.position}{a.bust.posFinishRank} · </span>
                    <span class="loss">{a.bust.vodp}</span>
                  </>
                ) : "—"}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>

  <h2>Most-Drafted Players Per Manager</h2>
  <p class="muted">Players each manager has drafted in multiple years.</p>
  <div class="card">
    <table>
      <thead>
        <tr>
          <th>Manager</th>
          <th>Top Picks</th>
        </tr>
      </thead>
      <tbody>
        {
          stats.map((s) => {
            const repeated = s.topPlayers.filter((p) => p.count > 1);
            const display = repeated.length > 0 ? repeated : s.topPlayers.slice(0, 1);
            return (
              <tr>
                <td>
                  <a href={`${base}/managers/${ownerKey(s.owner)}`}>{ownerLabel(s.owner)}</a>
                </td>
                <td>
                  {display.map((p, i) => (
                    <span>
                      {i > 0 && <span class="muted">, </span>}
                      <strong>{p.name}</strong>
                      <span class="muted"> ({p.position ?? "—"}) × {p.count}</span>
                      <span class="muted" style="font-size:0.8em"> [{p.years.join(", ")}]</span>
                    </span>
                  ))}
                </td>
              </tr>
            );
          })
        }
      </tbody>
    </table>
  </div>

  <div class="card">
    <h2 style="margin-top:0">First-Round Positions (All Time)</h2>
    <table>
      <thead>
        <tr>
          <th>Position</th>
          <th class="num">Count</th>
          <th class="num">%</th>
        </tr>
      </thead>
      <tbody>
        {
          firstRoundOrdered.map(([pos, n]) => (
            <tr>
              <td>{pos}</td>
              <td class="num">{n}</td>
              <td class="num">{((n / firstRoundTotal) * 100).toFixed(1)}%</td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>

  <h2 style="margin-top:2rem">By Manager</h2>
  <div class="card" style="overflow-x:auto">
    <table>
      <thead>
        <tr>
          <th>Manager</th>
          {TRACKED_POSITIONS.map((p) => <th class="num">{p}</th>)}
        </tr>
      </thead>
      <tbody>
        {
          stats.map((s) => (
            <tr>
              <td>
                <a href={`${base}/managers/${ownerKey(s.owner)}`}>
                  {ownerLabel(s.owner)}
                </a>
              </td>
              {TRACKED_POSITIONS.map((pos) => (
                <td class="num">{s.positionCounts[pos] || 0}</td>
              ))}
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>
</Layout>

<style>
  .position-chart-card { padding: 1rem 1.25rem 1.25rem; }
  .position-chart-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 0.75rem;
  }
  .position-owner-picker {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
  }
  .position-owner-picker select {
    background: var(--bg);
    color: var(--text);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.25rem 0.5rem;
    font: inherit;
  }
  .position-chart svg { width: 100%; height: auto; display: block; }
  .position-legend {
    list-style: none;
    margin: 0.5rem 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem 0.9rem;
    font-size: 0.8rem;
    color: var(--muted);
  }
  .position-legend li { display: inline-flex; align-items: center; gap: 0.35rem; }
  .position-legend .swatch {
    width: 10px;
    height: 10px;
    border-radius: 2px;
    display: inline-block;
  }
</style>

<script is:inline>
  (function () {
    const select = document.getElementById("position-owner");
    if (!select) return;
    const charts = document.querySelectorAll(".position-chart");
    select.addEventListener("change", function () {
      const v = select.value;
      charts.forEach(function (el) {
        el.style.display = el.getAttribute("data-owner") === v ? "" : "none";
      });
    });
  })();
</script>
