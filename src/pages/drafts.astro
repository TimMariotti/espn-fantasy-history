---
import Layout from "../layouts/Layout.astro";
import {
  buildDraftStats,
  ownerKey,
  ownerLabel,
  seasons,
  TRACKED_POSITIONS,
} from "../lib/data";

const stats = buildDraftStats();
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

// Aggregate first-round position pie across all drafts
const firstRoundAllTime: Record<string, number> = {};
for (const s of seasons) {
  for (const p of s.draft) {
    if (p.round === 1) {
      const pos = p.position || "?";
      firstRoundAllTime[pos] = (firstRoundAllTime[pos] || 0) + 1;
    }
  }
}
const firstRoundOrdered = Object.entries(firstRoundAllTime).sort((a, b) => b[1] - a[1]);
const firstRoundTotal = firstRoundOrdered.reduce((s, [, n]) => s + n, 0);

// Average pick by position across all years
const posPicks: Record<string, number[]> = {};
for (const s of seasons) {
  const teamCount = s.teams.length || 10;
  for (const p of s.draft) {
    const overall = (p.round - 1) * teamCount + p.pick;
    const pos = p.position || "?";
    posPicks[pos] = posPicks[pos] || [];
    posPicks[pos].push(overall);
  }
}
const avgByPos = Object.entries(posPicks)
  .map(([pos, picks]) => ({
    pos,
    avg: picks.reduce((s, n) => s + n, 0) / picks.length,
    count: picks.length,
  }))
  .filter((r) => r.count >= 5)
  .sort((a, b) => a.avg - b.avg);
---

<Layout title="Drafts · League History" active="drafts">
  <h1>Draft Stats</h1>

  <h2>By Manager</h2>
  <div class="card" style="overflow-x:auto">
    <table>
      <thead>
        <tr>
          <th>Manager</th>
          <th class="num">Drafts</th>
          <th class="num">Picks</th>
          <th class="num">Avg Pick</th>
          <th class="num">Keepers</th>
          {TRACKED_POSITIONS.map((p) => <th class="num">{p}</th>)}
        </tr>
      </thead>
      <tbody>
        {
          stats.map((s) => (
            <tr>
              <td>
                <a href={`${base}/managers/${ownerKey(s.owner)}`}>
                  {ownerLabel(s.owner)}
                </a>
              </td>
              <td class="num">{s.drafts}</td>
              <td class="num">{s.totalPicks}</td>
              <td class="num">{s.avgPick.toFixed(1)}</td>
              <td class="num">{s.keepers}</td>
              {TRACKED_POSITIONS.map((pos) => (
                <td class="num">{s.positionCounts[pos] || 0}</td>
              ))}
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>

  <div class="grid">
    <div class="card">
      <h2 style="margin-top:0">First-Round Positions (All Time)</h2>
      <table>
        <thead>
          <tr>
            <th>Position</th>
            <th class="num">Count</th>
            <th class="num">%</th>
          </tr>
        </thead>
        <tbody>
          {
            firstRoundOrdered.map(([pos, n]) => (
              <tr>
                <td>{pos}</td>
                <td class="num">{n}</td>
                <td class="num">{((n / firstRoundTotal) * 100).toFixed(1)}%</td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>

    <div class="card">
      <h2 style="margin-top:0">Average Pick By Position</h2>
      <p class="muted" style="margin-top:0">Lower = drafted earlier on average.</p>
      <table>
        <thead>
          <tr>
            <th>Position</th>
            <th class="num">Avg Pick</th>
            <th class="num">Picks</th>
          </tr>
        </thead>
        <tbody>
          {
            avgByPos.map((r) => (
              <tr>
                <td>{r.pos}</td>
                <td class="num">{r.avg.toFixed(1)}</td>
                <td class="num">{r.count}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
  </div>
</Layout>
